// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  ADMIN
}

enum DeliveryType {
  STANDARD
  EXPRESS
}

enum ShipmentStatus {
  PENDING
  PROCESSING
  SHIPPED
  OUT_FOR_DELIVERY
  DELIVERED
  CANCELLED
}

enum AddressType {
  SENDER
  RECEIVER
}

model User {
  id        String     @id @default(cuid())
  name      String
  email     String     @unique
  password  String
  role      Role       @default(USER)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  shipments Shipment[]

  @@index([email])
  @@map("users")
}

model Shipment {
  id           String         @id @default(cuid())
  orderId      String         @unique
  userId       String
  shipmentDate DateTime
  deliveryType DeliveryType   @default(STANDARD)
  fragile      Boolean        @default(false)
  insured      Boolean        @default(false)
  status       ShipmentStatus @default(PENDING)
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  addresses Address[]
  packages  Package[]

  @@index([userId])
  @@index([status])
  @@index([createdAt])
  @@map("shipments")
}

model Address {
  id         String      @id @default(cuid())
  shipmentId String
  type       AddressType
  name       String
  address    String
  city       String
  pincode    String
  createdAt  DateTime    @default(now())

  shipment Shipment @relation(fields: [shipmentId], references: [id], onDelete: Cascade)

  @@index([shipmentId])
  @@map("addresses")
}

model Package {
  id            String   @id @default(cuid())
  shipmentId    String
  name          String
  weight        Float
  length        Float
  width         Float
  height        Float
  declaredValue Float
  createdAt     DateTime @default(now())

  shipment Shipment @relation(fields: [shipmentId], references: [id], onDelete: Cascade)

  @@index([shipmentId])
  @@map("packages")
}

# ── Server ────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=5000

# ── Database ──────────────────────────────────────────────────────────────────
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="postgresql://shipforge:your_password_here@localhost:5432/shipforge"

# For Docker Compose (used by docker-compose.yml)
POSTGRES_USER=shipforge
POSTGRES_PASSWORD=your_password_here
POSTGRES_DB=shipforge

# ── JWT ───────────────────────────────────────────────────────────────────────
# IMPORTANT: Use a strong random secret in production (min 64 chars)
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace_this_with_a_long_random_secret_minimum_64_characters_long
JWT_EXPIRES_IN=7d

# ── Security ──────────────────────────────────────────────────────────────────
BCRYPT_ROUNDS=12

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins
CORS_ORIGIN=http://localhost:3000

# ── Rate Limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000   # 15 minutes in ms
RATE_LIMIT_MAX=100            # max requests per window (general)
AUTH_RATE_LIMIT_MAX=10        # max requests per window (auth endpoints)

# ── Seed ─────────────────────────────────────────────────────────────────────
SEED_ADMIN_EMAIL=admin@shipforge.com
SEED_ADMIN_PASSWORD=Admin@123!

# ── Copy this to .env and fill in values ─────────────────────────────────────

# PostgreSQL
POSTGRES_USER=shipforge
POSTGRES_PASSWORD=change_this_strong_password
POSTGRES_DB=shipforge

# Backend
JWT_SECRET=generate_with_node_-e_console.log(require('crypto').randomBytes(64).toString('hex'))
JWT_EXPIRES_IN=7d
BCRYPT_ROUNDS=12

# Admin seed (run: cd backend && npm run db:seed)
SEED_ADMIN_EMAIL=admin@shipforge.com
SEED_ADMIN_PASSWORD=Admin@123!

# ──────────────────────────────────────────────────────────────────────────────
# ShipForge — Environment Variables
# Copy this file to .env and fill in your values.
#
#   cp .env.example .env
#
# NEVER commit .env to git. It is already in .gitignore.
# ──────────────────────────────────────────────────────────────────────────────

# ── Database credentials (used by docker-compose.yml and DATABASE_URL) ────────
POSTGRES_USER=shipforge
POSTGRES_PASSWORD=change_this_password
POSTGRES_DB=shipforge

# ── PostgreSQL connection string (used by the backend) ───────────────────────
# When running via docker compose, the hostname is the service name: db
# When running locally without Docker, use: localhost
DATABASE_URL=postgresql://shipforge:change_this_password@db:5432/shipforge

# ── JWT — REQUIRED, must be a strong random string (min 64 characters) ───────
# Generate one with:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace_with_64_char_random_hex_string_see_comment_above

# ── Optional — sensible defaults are used if omitted ─────────────────────────
# JWT_EXPIRES_IN=7d
# BCRYPT_ROUNDS=12
# CORS_ORIGIN=http://localhost:3000

# ── Port overrides (optional) ─────────────────────────────────────────────────
# BACKEND_PORT=5000
# FRONTEND_PORT=3000

# ── Frontend API URL (the URL the browser uses to reach the backend) ──────────
# Change this to your public domain when deploying to production.
# NEXT_PUBLIC_API_URL=http://localhost:5000/api
